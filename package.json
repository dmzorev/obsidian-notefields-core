{
	"name": "notefields-core",
	"version": "1.0.2",
	"description": "Extensible rich property types and editors for Obsidian notes.",
	"main": "main.js",
	"types": "src/public-api.ts",
	"type": "module",
	"author": "Dmitry Zorev",
	"homepage": "https://github.com/dmzorev/obsidian-notefields-core#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dmzorev/obsidian-notefields-core.git"
	},
	"bugs": {
		"url": "https://github.com/dmzorev/obsidian-notefields-core/issues"
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"properties",
		"frontmatter",
		"metadata"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
